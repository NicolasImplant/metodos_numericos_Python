# ─── Generator method ─────────────────────────────────────────────────────────
# middle_squares | constant_multiplier | middle_products
# linear_congruential | multiplicative_congruential
# additive_congruential | quadratic_congruential
PRN_METHOD=linear_congruential

# ─── Seed and output size ─────────────────────────────────────────────────────
PRN_SEED=1234
PRN_COUNT=1000

# ─── Congruential parameters ──────────────────────────────────────────────────
PRN_MULTIPLIER=0       # a  (0 = auto-select prime for middle_* methods)
PRN_INCREMENT=0        # c  (linear congruential only)
PRN_MODULUS_EXPONENT=31  # m = 2^g

# ─── Quadratic congruential ───────────────────────────────────────────────────
PRN_COEFF_A=3
PRN_COEFF_B=5
PRN_COEFF_C=7

# ─── Additive congruential (lag vector, comma-separated) ──────────────────────
PRN_LAG_VECTOR=1009,2011,3001,4001,5003

# ─── Analysis and logging ─────────────────────────────────────────────────────
PRN_RUN_STATISTICS=true
PRN_LOG_LEVEL=INFO
