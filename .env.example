# ─── Problem selection ────────────────────────────────────────────────────────
# Type: integral | ode | pde
NM_PROBLEM_TYPE=ode

# Problem id (1-5 for integrals, 1-7 for ODEs, 1-5 for PDEs)
NM_PROBLEM_ID=1

# ─── Solver method ───────────────────────────────────────────────────────────
# Integrals:  simpson | trapezoidal | midpoint_rect
NM_INTEGRAL_METHOD=simpson

# ODEs:       runge_kutta4 | heun | midpoint | verlet
NM_ODE_METHOD=runge_kutta4

# PDEs:       explicit_euler_heat | wave_equation
NM_PDE_METHOD=explicit_euler_heat

# ─── Numerical parameters ────────────────────────────────────────────────────
NM_NUM_STEPS=10000

# ─── Output ──────────────────────────────────────────────────────────────────
# display → open GUI window  |  file → save PNG to NM_OUTPUT_DIR
NM_VISUALIZATION_BACKEND=file
NM_OUTPUT_DIR=output
NM_FIGURE_DPI=150
NM_FIGURE_FORMAT=png

# ─── Logging ─────────────────────────────────────────────────────────────────
NM_LOG_LEVEL=INFO
